# Configuração do Banco de Dados
# Substitua os valores de acordo com seu ambiente PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sistema-pedidos"

# Alternativamente, use variáveis separadas:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=usuario
# PGPASSWORD=senha
# PGDATABASE=sistema-pedidos
